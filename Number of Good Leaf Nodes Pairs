class Solution {
    private int result = 0;
    public int countPairs(TreeNode root, int distance) {
        result = 0;
        dDive(root, distance);
        return result;
    }

    private List<Integer> dDive(TreeNode root, int distance) {
        if (root == null) {
            return new ArrayList<>();
        }
        if (root.left == null && root.right == null) {
            List<Integer> temp = new ArrayList<>();
            temp.add(1);
            return temp;
        }
        List<Integer> lLeft = dDive(root.left, distance);
        List<Integer> rLeft = dDive(root.right, distance);
        for (int l : lLeft) {
            for (int r : rLeft) {
                if (l + r <= distance) {
                    result++;
                }
            }
        }
        List<Integer> currentDistances = new ArrayList<>();
        for (int l : lLeft) {
            if (l + 1 < distance) currentDistances.add(l + 1);
        }
        for (int r : rLeft) {
            if (r + 1 < distance) currentDistances.add(r + 1);
        }
        return currentDistances;
    }
}
