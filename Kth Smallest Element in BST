class Solution {
    int count=0,res=-1;
    public int kthSmallest(TreeNode root, int k) {
        inOrder(root,k);
        return res;
    }
    void inOrder(TreeNode node,int k){
        if(node==null) return;
        inOrder(node.left,k);
        count++;
        if(count==k){
            res=node.val;
            return;
        }
        inOrder(node.right,k);
    }
}
